EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FUNCTIONS_BASE_URL=

# Optional. Base URL of the web app on Firebase Hosting (no trailing slash).
# If unset, legal links use https://<EXPO_PUBLIC_FIREBASE_PROJECT_ID>.web.app
# EXPO_PUBLIC_WEB_APP_URL=https://your-custom-domain.com

# Native Google Sign-In (@react-native-google-signin/google-signin).
# WEB = OAuth client type "Web application" (same as Firebase Auth Google provider).
# IOS = OAuth client type "iOS" with bundle ID com.gmatwizard.mobile.
# No custom redirect URI (e.g. gmatwizard://) is registered in Google Cloud for this flow.
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
# Optional; used if you extend native sign-in for Android with this package.
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# RevenueCat (react-native-purchases). Public SDK key from RevenueCat dashboard — required for real IAP on dev client / EAS.
EXPO_PUBLIC_REVENUECAT_API_KEY=

# Dev: bypass all paywalls and treat user as Pro (useful for TestFlight/internal testing).
# EXPO_PUBLIC_DISABLE_PAYWALLS=1

# Expo Go: Metro aliases react-native-purchases to a JS mock (no native module). In production builds NODE_ENV=production disables this unless you set the flag to "1".
# EXPO_PUBLIC_IAP_USE_MOCK=1
# Start mock user without Pro to test paywall UI: EXPO_PUBLIC_IAP_MOCK_ENTITLED=0
